     -->


    


    <!-- https://tetherless-world.github.io/idea-ontology/ontology#Approach -->


    <owl:Class rdf:about="https://tetherless-world.github.io/idea-ontology/ontology#Approach">
        <rdfs:subClassOf rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Argument"/>
    </owl:Class>
    


    <!-- https://tetherless-world.github.io/idea-ontology/ontology#Argument -->


    <owl:Class rdf:about="https://tetherless-world.github.io/idea-ontology/ontology#Argument"/>
    


    <!-- https://tetherless-world.github.io/idea-ontology/ontology#Artifact -->


    <owl:Class rdf:about="https://tetherless-world.github.io/idea-ontology/ontology#Artifact"/>
    


    <!-- https://tetherless-world.github.io/idea-ontology/ontology#Backing -->


    <owl:Class rdf:about="https://tetherless-world.github.io/idea-ontology/ontology#Backing">
        <rdfs:subClassOf rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Argument"/>
        <rdfs:comment>Sort of credentials that certifies the warrant - e.g., the OWL 2 document specifications.</rdfs:comment>
        <rdfs:isDefinedBy>http://purl.org/spar/amo/Backing</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- https://tetherless-world.github.io/idea-ontology/ontology#Cause -->


    <owl:Class rdf:about="https://tetherless-world.github.io/idea-ontology/ontology#Cause">
        <rdfs:subClassOf rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Descriptor"/>
        <rdfs:comment>A situation that, by means other than motivating a violational or non-violational action caused the situation presented in the artifact.</rdfs:comment>
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </owl:Class>
    


    <!-- https://tetherless-world.github.io/idea-ontology/ontology#Circumstance -->


    <owl:Class rdf:about="https://tetherless-world.github.io/idea-ontology/ontology#Circumstance">
        <rdfs:subClassOf rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Descriptor"/>
        <rdfs:comment>The proposition providing the situation presents the framework for interpreting the artifact.</rdfs:comment>
