<?xml version="1.0"?>
<rdf:RDF xmlns="https://tetherless-world.github.io/idea-ontology/ontology#"
     xml:base="https://tetherless-world.github.io/idea-ontology/ontology"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="https://tetherless-world.github.io/idea-ontology/ontology">
        <owl:versionIRI rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology/releases/3.1.0"/>
        <owl:versionInfo></owl:versionInfo>
        <owl:versionInfo>3.1.0</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2004/02/skos/core#altLabel -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#altLabel">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Artifact"/>
        <rdfs:range rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Artifact"/>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#closeMatch -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#closeMatch">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Artifact"/>
        <rdfs:range rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Artifact"/>
    </owl:ObjectProperty>
    


    <!-- https://tetherless-world.github.io/idea-ontology/ontology#FeatureOf -->


    <owl:ObjectProperty rdf:about="https://tetherless-world.github.io/idea-ontology/ontology#FeatureOf">
        <rdfs:domain rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Artifact"/>
        <rdfs:range rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Artifact"/>
        <rdfs:seeAlso>http://arxiv.org/abs/1808.09602</rdfs:seeAlso>
    </owl:ObjectProperty>
    


    <!-- https://tetherless-world.github.io/idea-ontology/ontology#HyponymOf -->


    <owl:ObjectProperty rdf:about="https://tetherless-world.github.io/idea-ontology/ontology#HyponymOf">
        <rdfs:domain rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Artifact"/>
        <rdfs:range rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Artifact"/>
        <rdfs:seeAlso>http://arxiv.org/abs/1808.09602</rdfs:seeAlso>
    </owl:ObjectProperty>
    


    <!-- https://tetherless-world.github.io/idea-ontology/ontology#PartOf -->


    <owl:ObjectProperty rdf:about="https://tetherless-world.github.io/idea-ontology/ontology#PartOf">
        <rdfs:domain rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Artifact"/>
        <rdfs:range rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Artifact"/>
        <rdfs:seeAlso>http://arxiv.org/abs/1808.09602</rdfs:seeAlso>
    </owl:ObjectProperty>
    


    <!-- https://tetherless-world.github.io/idea-ontology/ontology#backs -->


    <owl:ObjectProperty rdf:about="https://tetherless-world.github.io/idea-ontology/ontology#backs">
        <rdfs:domain rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Backing"/>
        <rdfs:range rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Warrant"/>
        <rdfs:comment>A backing that attests the warrant of an argument.</rdfs:comment>
        <rdfs:isDefinedBy>http://purl.org/spar/amo/backs</rdfs:isDefinedBy>
    </owl:ObjectProperty>
    


    <!-- https://tetherless-world.github.io/idea-ontology/ontology#causes -->


    <owl:ObjectProperty rdf:about="https://tetherless-world.github.io/idea-ontology/ontology#causes">
        <rdfs:domain rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Cause"/>
        <rdfs:range rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Artifact"/>
        <rdfs:comment>the situation presented in the proposition as a cause for the volitional or non-violation action presented in the artifact</rdfs:comment>
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </owl:ObjectProperty>
    


    <!-- https://tetherless-world.github.io/idea-ontology/ontology#concede -->


    <owl:ObjectProperty rdf:about="https://tetherless-world.github.io/idea-ontology/ontology#concede">
        <rdfs:domain rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Artifact"/>
        <rdfs:range rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Argument"/>
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </owl:ObjectProperty>
    


    <!-- https://tetherless-world.github.io/idea-ontology/ontology#condition -->


    <owl:ObjectProperty rdf:about="https://tetherless-world.github.io/idea-ontology/ontology#condition">
        <rdfs:domain rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Condition"/>
        <rdfs:range rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Artifact"/>
        <rdfs:comment>recognizes how the realization of the situation presented in artifact depends on the realization of the situation presented in the proposition.</rdfs:comment>
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </owl:ObjectProperty>
    


    <!-- https://tetherless-world.github.io/idea-ontology/ontology#contextualizes -->


    <owl:ObjectProperty rdf:about="https://tetherless-world.github.io/idea-ontology/ontology#contextualizes">
        <rdfs:domain rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Artifact"/>
        <rdfs:domain rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Circumstance"/>
        <rdfs:range rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Argument"/>
        <rdfs:range rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Artifact"/>
        <rdfs:comment>the proposition provides the framework for interpreting the reference artifact.</rdfs:comment>
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </owl:ObjectProperty>
    


    <!-- https://tetherless-world.github.io/idea-ontology/ontology#contrast -->


    <owl:ObjectProperty rdf:about="https://tetherless-world.github.io/idea-ontology/ontology#contrast">
        <rdfs:domain rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Artifact"/>
        <rdfs:range rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Argument"/>
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </owl:ObjectProperty>
    


    <!-- https://tetherless-world.github.io/idea-ontology/ontology#elaborates -->


    <owl:ObjectProperty rdf:about="https://tetherless-world.github.io/idea-ontology/ontology#elaborates">
        <rdfs:domain rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Elaboration"/>
        <rdfs:range rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Artifact"/>
        <rdfs:seeAlso>The proposition presents additiona detail about the situation or some element of subject mattern which is presentes in the artifact or inferentially accessible in N in one or more of the way listed below;
set: member
abstract : instance 
whole : part
process : step
object : attribute
generalization : specific</rdfs:seeAlso>
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </owl:ObjectProperty>
    


    <!-- https://tetherless-world.github.io/idea-ontology/ontology#enables -->


    <owl:ObjectProperty rdf:about="https://tetherless-world.github.io/idea-ontology/ontology#enables">
        <rdfs:domain rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Artifact"/>
        <rdfs:range rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Argument"/>
        <rdfs:comment>potential ability to perform the action presented in artifact increases</rdfs:comment>
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </owl:ObjectProperty>
    


    <!-- https://tetherless-world.github.io/idea-ontology/ontology#evaluates -->


    <owl:ObjectProperty rdf:about="https://tetherless-world.github.io/idea-ontology/ontology#evaluates">
        <rdfs:domain rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Evaluation"/>
        <rdfs:range rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Artifact"/>
        <rdfs:comment>situation presented in the proposition assess the sutiation presented in the artifact and recognizes the value it assigns.</rdfs:comment>
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </owl:ObjectProperty>
    


    <!-- https://tetherless-world.github.io/idea-ontology/ontology#evidence -->


    <owl:ObjectProperty rdf:about="https://tetherless-world.github.io/idea-ontology/ontology#evidence">
        <rdfs:domain rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Approach"/>
        <rdfs:range rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Evidence"/>
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </owl:ObjectProperty>
    


    <!-- https://tetherless-world.github.io/idea-ontology/ontology#forces -->


    <owl:ObjectProperty rdf:about="https://tetherless-world.github.io/idea-ontology/ontology#forces">
        <rdfs:domain rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Qualifier"/>
        <rdfs:range rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Claim"/>
        <rdfs:comment>A qualifier that expresses as degree of force concerning a claim of an argument.</rdfs:comment>
        <rdfs:isDefinedBy>http://purl.org/spar/amo/forces</rdfs:isDefinedBy>
    </owl:ObjectProperty>
    


    <!-- https://tetherless-world.github.io/idea-ontology/ontology#interprets -->


    <owl:ObjectProperty rdf:about="https://tetherless-world.github.io/idea-ontology/ontology#interprets">
        <rdfs:domain rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Interpretation"/>
        <rdfs:range rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Artifact"/>
        <rdfs:comment>the situation presented in the artifact to a framework of ideas not involved in the knowledge presented in the artifact itself.</rdfs:comment>
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </owl:ObjectProperty>
    


    <!-- https://tetherless-world.github.io/idea-ontology/ontology#isValidUnless -->


    <owl:ObjectProperty rdf:about="https://tetherless-world.github.io/idea-ontology/ontology#isValidUnless">
        <rdfs:domain rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Claim"/>
        <rdfs:range rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Rebuttal"/>
        <rdfs:comment>A claim that is restricted by a rebuttal of an argument.</rdfs:comment>
        <rdfs:isDefinedBy>http://purl.org/spar/amo/isValidUnless</rdfs:isDefinedBy>
    </owl:ObjectProperty>
    


    <!-- https://tetherless-world.github.io/idea-ontology/ontology#justify -->


    <owl:ObjectProperty rdf:about="https://tetherless-world.github.io/idea-ontology/ontology#justify">
        <rdfs:domain rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Artifact"/>
        <rdfs:range rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Argument"/>
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </owl:ObjectProperty>
    


    <!-- https://tetherless-world.github.io/idea-ontology/ontology#leadsTo -->


    <owl:ObjectProperty rdf:about="https://tetherless-world.github.io/idea-ontology/ontology#leadsTo">
        <rdfs:domain rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Warrant"/>
        <rdfs:range rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Claim"/>
        <rdfs:comment>A warrant that points to a claim from the related evidence within an argument.</rdfs:comment>
        <rdfs:isDefinedBy>http://purl.org/spar/amo/leadsTo</rdfs:isDefinedBy>
    </owl:ObjectProperty>
    


    <!-- https://tetherless-world.github.io/idea-ontology/ontology#mentions -->


    <owl:ObjectProperty rdf:about="https://tetherless-world.github.io/idea-ontology/ontology#mentions">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://tetherless-world.github.io/idea-ontology/ontology#Argument"/>
                    <rdf:Description rdf:about="https://tetherless-world.github.io/idea-ontology/ontology#Descriptor"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Artifact"/>
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </owl:ObjectProperty>
    


    <!-- https://tetherless-world.github.io/idea-ontology/ontology#motivates -->


    <owl:ObjectProperty rdf:about="https://tetherless-world.github.io/idea-ontology/ontology#motivates">
        <rdfs:domain rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Artifact"/>
        <rdfs:domain rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Idea"/>
        <rdfs:range rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Approach"/>
        <rdfs:range rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Argument"/>
        <rdfs:comment>desire to perform action presented in the artifact is increased</rdfs:comment>
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </owl:ObjectProperty>
    


    <!-- https://tetherless-world.github.io/idea-ontology/ontology#proves -->


    <owl:ObjectProperty rdf:about="https://tetherless-world.github.io/idea-ontology/ontology#proves">
        <rdfs:domain rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Evidence"/>
        <rdfs:range rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Claim"/>
        <rdfs:comment>An evidence that founds a claim of an argument.</rdfs:comment>
        <rdfs:isDefinedBy>http://purl.org/spar/amo/proves</rdfs:isDefinedBy>
    </owl:ObjectProperty>
    


    <!-- https://tetherless-world.github.io/idea-ontology/ontology#purposes -->


    <owl:ObjectProperty rdf:about="https://tetherless-world.github.io/idea-ontology/ontology#purposes">
        <rdfs:domain rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Purpose"/>
        <rdfs:range rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Artifact"/>
        <rdfs:comment>the activity in the artifact is initiated in order to realize the proposition.</rdfs:comment>
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </owl:ObjectProperty>
    


    <!-- https://tetherless-world.github.io/idea-ontology/ontology#responsesTo -->


    <owl:ObjectProperty rdf:about="https://tetherless-world.github.io/idea-ontology/ontology#responsesTo">
        <rdfs:domain rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Approach"/>
        <rdfs:domain rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Idea"/>
        <rdfs:range rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Issue"/>
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </owl:ObjectProperty>
    


    <!-- https://tetherless-world.github.io/idea-ontology/ontology#restates -->


    <owl:ObjectProperty rdf:about="https://tetherless-world.github.io/idea-ontology/ontology#restates">
        <rdfs:domain rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Restatement"/>
        <rdfs:range rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Artifact"/>
        <rdfs:comment>a proposition as a restatement of the artifact.</rdfs:comment>
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </owl:ObjectProperty>
    


    <!-- https://tetherless-world.github.io/idea-ontology/ontology#result -->


    <owl:ObjectProperty rdf:about="https://tetherless-world.github.io/idea-ontology/ontology#result">
        <rdfs:domain rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Result"/>
        <rdfs:range rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Artifact"/>
        <rdfs:comment>recognizes that the situation presented in the artifact, could be a cuase for the action or situation presented in the proposition.</rdfs:comment>
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </owl:ObjectProperty>
    


    <!-- https://tetherless-world.github.io/idea-ontology/ontology#solves -->


    <owl:ObjectProperty rdf:about="https://tetherless-world.github.io/idea-ontology/ontology#solves">
        <rdfs:domain rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Solutionhood"/>
        <rdfs:range rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Artifact"/>
        <rdfs:comment>The artifact is a solution to the problem stated in the proposition.</rdfs:comment>
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </owl:ObjectProperty>
    


    <!-- https://tetherless-world.github.io/idea-ontology/ontology#summarizes -->


    <owl:ObjectProperty rdf:about="https://tetherless-world.github.io/idea-ontology/ontology#summarizes">
        <rdfs:domain rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Summary"/>
        <rdfs:range rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Artifact"/>
        <rdfs:comment>a proposition as a shorter restatement of the artifact.</rdfs:comment>
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </owl:ObjectProperty>
    


    <!-- https://tetherless-world.github.io/idea-ontology/ontology#supports -->


    <owl:ObjectProperty rdf:about="https://tetherless-world.github.io/idea-ontology/ontology#supports">
        <rdfs:domain rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Artifact"/>
        <rdfs:domain rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Evidence"/>
        <rdfs:range rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Argument"/>
        <rdfs:range rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Warrant"/>
        <rdfs:comment>An evidence that supports a warrant of an argument.</rdfs:comment>
        <rdfs:isDefinedBy>http://purl.org/spar/amo/supports</rdfs:isDefinedBy>
    </owl:ObjectProperty>
    


    <!-- https://tetherless-world.github.io/idea-ontology/ontology#usedFor -->


    <owl:ObjectProperty rdf:about="https://tetherless-world.github.io/idea-ontology/ontology#usedFor">
        <rdfs:domain rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Artifact"/>
        <rdfs:range rdf:resource="https://tetherless-world.github.io/idea-ontology/ontology#Artifact"/>
        <rdfs:seeAlso>http://arxiv.org/abs/1808.09602</rdfs:seeAlso>
    </owl:ObjectProperty>
    


