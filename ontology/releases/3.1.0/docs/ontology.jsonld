  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://tetherless-world.github.io/idea-ontology/ontology#Descriptor"
  } ]
}, {
  "@id" : "https://tetherless-world.github.io/idea-ontology/ontology#Circumstance",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "The proposition providing the situation presents the framework for interpreting the artifact."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@value" : "https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://tetherless-world.github.io/idea-ontology/ontology#Descriptor"
  } ]
