  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://tetherless-world.github.io/idea-ontology/ontology#Descriptor"
  } ]
}, {
  "@id" : "https://tetherless-world.github.io/idea-ontology/ontology#Qualifier",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Words or phrases that express the degree of certainty of the claim such as “certainly”, “possible”, “probably”, “presumably”, etc."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "http://purl.org/spar/amo/Qualifier"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://tetherless-world.github.io/idea-ontology/ontology#Argument"
  } ]
}, {
  "@id" : "https://tetherless-world.github.io/idea-ontology/ontology#Rebuttal",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Restrictions that may be applied to the claim - 'Unless a reasoner for OWL 2 proves that it is not consistent'."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "http://purl.org/spar/amo/Rebuttal"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://tetherless-world.github.io/idea-ontology/ontology#Argument"
  } ]
}, {
  "@id" : "https://tetherless-world.github.io/idea-ontology/ontology#Restatement",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "a proposition restates the artifact, where the proposition and the artifact are of comparable bulk."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@value" : "https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://tetherless-world.github.io/idea-ontology/ontology#Descriptor"
  } ]
}, {
  "@id" : "https://tetherless-world.github.io/idea-ontology/ontology#Result",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "A Proposition presets a situation that could ahve been caused by the situation presented in the artifact."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@value" : "https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://tetherless-world.github.io/idea-ontology/ontology#Descriptor"
  } ]
}, {
  "@id" : "https://tetherless-world.github.io/idea-ontology/ontology#Solutionhood",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@value" : "The proposition representing the situation that solves by the artifact."
  }, {
    "@value" : "https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://tetherless-world.github.io/idea-ontology/ontology#Descriptor"
  } ]
}, {
  "@id" : "https://tetherless-world.github.io/idea-ontology/ontology#Summary",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "A restatement of the content of the artifact, that is shorter in bulk."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@value" : "https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://tetherless-world.github.io/idea-ontology/ontology#Descriptor"
  } ]
}, {
  "@id" : "https://tetherless-world.github.io/idea-ontology/ontology#Task",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Applications, problems to solve, systems to construct. - e.g. information extraction, machine reading system, image segmentation, etc."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@value" : "http://arxiv.org/abs/1808.09602"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://tetherless-world.github.io/idea-ontology/ontology#Artifact"
  } ]
}, {
  "@id" : "https://tetherless-world.github.io/idea-ontology/ontology#Term",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "General terms or pronouns that may refer to a entity but are not themselves informative, often used as connection words."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@value" : "http://arxiv.org/abs/1808.09602"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://tetherless-world.github.io/idea-ontology/ontology#Artifact"
  } ]
}, {
  "@id" : "https://tetherless-world.github.io/idea-ontology/ontology#Warrant",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "A statement bridging from the evidence to the claim - e.g., 'An ontology developed in OWL is a consistent OWL ontology'."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "http://purl.org/spar/amo/Warrant"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://tetherless-world.github.io/idea-ontology/ontology#Argument"
  } ]
}, {
  "@id" : "https://tetherless-world.github.io/idea-ontology/ontology#backs",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "A backing that attests the warrant of an argument."
