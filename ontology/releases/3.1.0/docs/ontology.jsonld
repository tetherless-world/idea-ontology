    "@value" : "a proposition relates the situation presented in the artifact to a framework of ideas not involved in the artifact itself."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@value" : "https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf"
