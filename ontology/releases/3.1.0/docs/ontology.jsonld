  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "http://purl.org/spar/amo/Claim"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://tetherless-world.github.io/idea-ontology/ontology#Argument"
  } ]
}, {
  "@id" : "https://tetherless-world.github.io/idea-ontology/ontology#Condition",
