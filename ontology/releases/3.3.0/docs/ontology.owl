    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://w3id.org/twc/sudo/ontology#Approach -->


    <owl:Class rdf:about="https://w3id.org/twc/sudo/ontology#Approach">
        <rdfs:subClassOf rdf:resource="https://w3id.org/twc/sudo/ontology#Argument"/>
    </owl:Class>
    


    <!-- https://w3id.org/twc/sudo/ontology#Argument -->


    <owl:Class rdf:about="https://w3id.org/twc/sudo/ontology#Argument">
        <rdfs:subClassOf rdf:resource="https://w3id.org/twc/sudo/ontology#Proposition"/>
    </owl:Class>
    


    <!-- https://w3id.org/twc/sudo/ontology#Artifact -->


    <owl:Class rdf:about="https://w3id.org/twc/sudo/ontology#Artifact">
        <rdfs:subClassOf rdf:resource="https://w3id.org/twc/sudo/ontology#Concept"/>
    </owl:Class>
    


    <!-- https://w3id.org/twc/sudo/ontology#Backing -->


    <owl:Class rdf:about="https://w3id.org/twc/sudo/ontology#Backing">
        <rdfs:subClassOf rdf:resource="https://w3id.org/twc/sudo/ontology#Argument"/>
        <rdfs:comment>Sort of credentials that certifies the warrant - e.g., the OWL 2 document specifications.</rdfs:comment>
        <rdfs:isDefinedBy>http://purl.org/spar/amo/Backing</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- https://w3id.org/twc/sudo/ontology#Cause -->


    <owl:Class rdf:about="https://w3id.org/twc/sudo/ontology#Cause">
        <rdfs:subClassOf rdf:resource="https://w3id.org/twc/sudo/ontology#Descriptor"/>
        <rdfs:comment>A situation that, by means other than motivating a violational or non-violational action caused the situation presented in the artifact.</rdfs:comment>
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </owl:Class>
    


    <!-- https://w3id.org/twc/sudo/ontology#Circumstance -->


    <owl:Class rdf:about="https://w3id.org/twc/sudo/ontology#Circumstance">
        <rdfs:subClassOf rdf:resource="https://w3id.org/twc/sudo/ontology#Descriptor"/>
        <rdfs:comment>The proposition providing the situation presents the framework for interpreting the artifact.</rdfs:comment>
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </owl:Class>
    


    <!-- https://w3id.org/twc/sudo/ontology#Claim -->


    <owl:Class rdf:about="https://w3id.org/twc/sudo/ontology#Claim">
        <rdfs:subClassOf rdf:resource="https://w3id.org/twc/sudo/ontology#Argument"/>
        <rdfs:comment>A fact that must be established - e.g., &apos;This is a consistent OWL ontology&apos;.</rdfs:comment>
        <rdfs:isDefinedBy>http://purl.org/spar/amo/Claim</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- https://w3id.org/twc/sudo/ontology#Concept -->


    <owl:Class rdf:about="https://w3id.org/twc/sudo/ontology#Concept"/>
    


    <!-- https://w3id.org/twc/sudo/ontology#Condition -->


    <owl:Class rdf:about="https://w3id.org/twc/sudo/ontology#Condition">
        <rdfs:subClassOf rdf:resource="https://w3id.org/twc/sudo/ontology#Descriptor"/>
        <rdfs:comment>A realization of the situation presented in the proposition enables the realization of the situation presented in the artifact.</rdfs:comment>
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </owl:Class>
    


    <!-- https://w3id.org/twc/sudo/ontology#Descriptor -->


    <owl:Class rdf:about="https://w3id.org/twc/sudo/ontology#Descriptor">
        <rdfs:subClassOf rdf:resource="https://w3id.org/twc/sudo/ontology#Proposition"/>
    </owl:Class>
    


    <!-- https://w3id.org/twc/sudo/ontology#Elaboration -->


    <owl:Class rdf:about="https://w3id.org/twc/sudo/ontology#Elaboration">
        <rdfs:subClassOf rdf:resource="https://w3id.org/twc/sudo/ontology#Descriptor"/>
        <rdfs:comment>Additional details about the situation or some element of subject matter related to the artifact.</rdfs:comment>
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </owl:Class>
    


    <!-- https://w3id.org/twc/sudo/ontology#Evaluation -->


    <owl:Class rdf:about="https://w3id.org/twc/sudo/ontology#Evaluation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/twc/sudo/ontology#Descriptor"/>
        <rdfs:comment>a proposition related the situation in the artifact to degree of context&apos;s positive regards toward the situation presented in the artifact.</rdfs:comment>
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </owl:Class>
    


    <!-- https://w3id.org/twc/sudo/ontology#Evidence -->


    <owl:Class rdf:about="https://w3id.org/twc/sudo/ontology#Evidence">
        <rdfs:subClassOf rdf:resource="https://w3id.org/twc/sudo/ontology#Argument"/>
        <rdfs:comment>A fact that represents a foundation for the claim - e.g., &apos;This ontology was developed in OWL&apos;.</rdfs:comment>
        <rdfs:isDefinedBy>http://purl.org/spar/amo/Evidence</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- https://w3id.org/twc/sudo/ontology#Idea -->


    <owl:Class rdf:about="https://w3id.org/twc/sudo/ontology#Idea">
        <rdfs:subClassOf rdf:resource="https://w3id.org/twc/sudo/ontology#Argument"/>
    </owl:Class>
    


    <!-- https://w3id.org/twc/sudo/ontology#Interpretation -->


    <owl:Class rdf:about="https://w3id.org/twc/sudo/ontology#Interpretation">
        <rdfs:subClassOf rdf:resource="https://w3id.org/twc/sudo/ontology#Descriptor"/>
        <rdfs:comment>a proposition relates the situation presented in the artifact to a framework of ideas not involved in the artifact itself.</rdfs:comment>
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </owl:Class>
    


    <!-- https://w3id.org/twc/sudo/ontology#Issue -->


    <owl:Class rdf:about="https://w3id.org/twc/sudo/ontology#Issue">
        <rdfs:subClassOf rdf:resource="https://w3id.org/twc/sudo/ontology#Argument"/>
    </owl:Class>
    


    <!-- https://w3id.org/twc/sudo/ontology#Material -->


    <owl:Class rdf:about="https://w3id.org/twc/sudo/ontology#Material">
        <rdfs:subClassOf rdf:resource="https://w3id.org/twc/sudo/ontology#Artifact"/>
        <rdfs:comment>Data, datasets, resources, Corpus, Knowledge base. - e.g. image data, speech data, stereo images, bilingual dictionary, paraphrased questions, CoNLL, Panntreebank, WordNet, Wikipedia, etc.</rdfs:comment>
        <rdfs:seeAlso>http://arxiv.org/abs/1808.09602</rdfs:seeAlso>
    </owl:Class>
    


    <!-- https://w3id.org/twc/sudo/ontology#Method -->


    <owl:Class rdf:about="https://w3id.org/twc/sudo/ontology#Method">
        <rdfs:subClassOf rdf:resource="https://w3id.org/twc/sudo/ontology#Artifact"/>
        <rdfs:comment>Methods , models, systems to use, or tools, components of a system, frameworks. - e.g. language model, CORENLP, POS parser, kernel method, etc.</rdfs:comment>
        <rdfs:seeAlso>http://arxiv.org/abs/1808.09602</rdfs:seeAlso>
    </owl:Class>
    


    <!-- https://w3id.org/twc/sudo/ontology#Metric -->


    <owl:Class rdf:about="https://w3id.org/twc/sudo/ontology#Metric">
        <rdfs:subClassOf rdf:resource="https://w3id.org/twc/sudo/ontology#Artifact"/>
        <rdfs:comment>Metrics, measures, or entities that can express quality of a system/method. - e.g. F1, BLEU, Precision, Recall, ROC curve, mean reciprocal rank, mean-squared error, robustness, time complexity, etc.</rdfs:comment>
        <rdfs:seeAlso>http://arxiv.org/abs/1808.09602</rdfs:seeAlso>
    </owl:Class>
    


    <!-- https://w3id.org/twc/sudo/ontology#Proposition -->


    <owl:Class rdf:about="https://w3id.org/twc/sudo/ontology#Proposition"/>
    


    <!-- https://w3id.org/twc/sudo/ontology#Purpose -->


    <owl:Class rdf:about="https://w3id.org/twc/sudo/ontology#Purpose">
        <rdfs:subClassOf rdf:resource="https://w3id.org/twc/sudo/ontology#Descriptor"/>
        <rdfs:comment>A situation to be realized through the activity in the artifact.</rdfs:comment>
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </owl:Class>
    


    <!-- https://w3id.org/twc/sudo/ontology#Qualifier -->


    <owl:Class rdf:about="https://w3id.org/twc/sudo/ontology#Qualifier">
        <rdfs:subClassOf rdf:resource="https://w3id.org/twc/sudo/ontology#Argument"/>
        <rdfs:comment>Words or phrases that express the degree of certainty of the claim such as “certainly”, “possible”, “probably”, “presumably”, etc.</rdfs:comment>
        <rdfs:isDefinedBy>http://purl.org/spar/amo/Qualifier</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- https://w3id.org/twc/sudo/ontology#Rebuttal -->


    <owl:Class rdf:about="https://w3id.org/twc/sudo/ontology#Rebuttal">
        <rdfs:subClassOf rdf:resource="https://w3id.org/twc/sudo/ontology#Argument"/>
        <rdfs:comment>Restrictions that may be applied to the claim - &apos;Unless a reasoner for OWL 2 proves that it is not consistent&apos;.</rdfs:comment>
        <rdfs:isDefinedBy>http://purl.org/spar/amo/Rebuttal</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- https://w3id.org/twc/sudo/ontology#Restatement -->


    <owl:Class rdf:about="https://w3id.org/twc/sudo/ontology#Restatement">
        <rdfs:subClassOf rdf:resource="https://w3id.org/twc/sudo/ontology#Descriptor"/>
        <rdfs:comment>a proposition restates the artifact, where the proposition and the artifact are of comparable bulk.</rdfs:comment>
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </owl:Class>
    


    <!-- https://w3id.org/twc/sudo/ontology#Result -->


    <owl:Class rdf:about="https://w3id.org/twc/sudo/ontology#Result">
        <rdfs:subClassOf rdf:resource="https://w3id.org/twc/sudo/ontology#Descriptor"/>
        <rdfs:comment>A Proposition presets a situation that could ahve been caused by the situation presented in the artifact.</rdfs:comment>
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </owl:Class>
    


    <!-- https://w3id.org/twc/sudo/ontology#Solutionhood -->


    <owl:Class rdf:about="https://w3id.org/twc/sudo/ontology#Solutionhood">
        <rdfs:subClassOf rdf:resource="https://w3id.org/twc/sudo/ontology#Descriptor"/>
        <rdfs:seeAlso>The proposition representing the situation that solves by the artifact.</rdfs:seeAlso>
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </owl:Class>
    


    <!-- https://w3id.org/twc/sudo/ontology#Summary -->


    <owl:Class rdf:about="https://w3id.org/twc/sudo/ontology#Summary">
        <rdfs:subClassOf rdf:resource="https://w3id.org/twc/sudo/ontology#Descriptor"/>
        <rdfs:comment>A restatement of the content of the artifact, that is shorter in bulk.</rdfs:comment>
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </owl:Class>
    


    <!-- https://w3id.org/twc/sudo/ontology#Task -->


    <owl:Class rdf:about="https://w3id.org/twc/sudo/ontology#Task">
        <rdfs:subClassOf rdf:resource="https://w3id.org/twc/sudo/ontology#Artifact"/>
        <rdfs:comment>Applications, problems to solve, systems to construct. - e.g. information extraction, machine reading system, image segmentation, etc.</rdfs:comment>
        <rdfs:seeAlso>http://arxiv.org/abs/1808.09602</rdfs:seeAlso>
    </owl:Class>
    


    <!-- https://w3id.org/twc/sudo/ontology#Term -->


    <owl:Class rdf:about="https://w3id.org/twc/sudo/ontology#Term">
        <rdfs:subClassOf rdf:resource="https://w3id.org/twc/sudo/ontology#Artifact"/>
        <rdfs:comment>General terms or pronouns that may refer to a entity but are not themselves informative, often used as connection words.</rdfs:comment>
        <rdfs:seeAlso>http://arxiv.org/abs/1808.09602</rdfs:seeAlso>
    </owl:Class>
    


    <!-- https://w3id.org/twc/sudo/ontology#Warrant -->


    <owl:Class rdf:about="https://w3id.org/twc/sudo/ontology#Warrant">
        <rdfs:subClassOf rdf:resource="https://w3id.org/twc/sudo/ontology#Argument"/>
        <rdfs:comment>A statement bridging from the evidence to the claim - e.g., &apos;An ontology developed in OWL is a consistent OWL ontology&apos;.</rdfs:comment>
        <rdfs:isDefinedBy>http://purl.org/spar/amo/Warrant</rdfs:isDefinedBy>
    </owl:Class>
    


