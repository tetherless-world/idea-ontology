    //
    // Annotations
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    <rdf:Description rdf:about="https://w3id.org/twc/sudo/ontology#FeatureOf">
        <rdfs:seeAlso>http://arxiv.org/abs/1808.09602</rdfs:seeAlso>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/twc/sudo/ontology#HyponymOf">
        <rdfs:seeAlso>http://arxiv.org/abs/1808.09602</rdfs:seeAlso>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/twc/sudo/ontology#PartOf">
        <rdfs:seeAlso>http://arxiv.org/abs/1808.09602</rdfs:seeAlso>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/twc/sudo/ontology#backs">
        <rdfs:comment>A backing that attests the warrant of an argument.</rdfs:comment>
        <rdfs:isDefinedBy>http://purl.org/spar/amo/backs</rdfs:isDefinedBy>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/twc/sudo/ontology#causes">
        <rdfs:comment>the situation presented in the proposition as a cause for the volitional or non-violation action presented in the artifact</rdfs:comment>
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/twc/sudo/ontology#concede">
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/twc/sudo/ontology#condition">
        <rdfs:comment>recognizes how the realization of the situation presented in artifact depends on the realization of the situation presented in the proposition.</rdfs:comment>
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/twc/sudo/ontology#contextualizes">
        <rdfs:comment>the proposition provides the framework for interpreting the reference artifact.</rdfs:comment>
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/twc/sudo/ontology#contrast">
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/twc/sudo/ontology#elaborates">
        <rdfs:seeAlso>The proposition presents additiona detail about the situation or some element of subject mattern which is presentes in the artifact or inferentially accessible in N in one or more of the way listed below;
set: member
abstract : instance 
whole : part
process : step
object : attribute
generalization : specific</rdfs:seeAlso>
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/twc/sudo/ontology#enables">
        <rdfs:comment>potential ability to perform the action presented in artifact increases</rdfs:comment>
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/twc/sudo/ontology#evaluates">
        <rdfs:comment>situation presented in the proposition assess the sutiation presented in the artifact and recognizes the value it assigns.</rdfs:comment>
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/twc/sudo/ontology#evidence">
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/twc/sudo/ontology#forces">
        <rdfs:comment>A qualifier that expresses as degree of force concerning a claim of an argument.</rdfs:comment>
        <rdfs:isDefinedBy>http://purl.org/spar/amo/forces</rdfs:isDefinedBy>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/twc/sudo/ontology#interprets">
        <rdfs:comment>the situation presented in the artifact to a framework of ideas not involved in the knowledge presented in the artifact itself.</rdfs:comment>
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/twc/sudo/ontology#isValidUnless">
        <rdfs:comment>A claim that is restricted by a rebuttal of an argument.</rdfs:comment>
        <rdfs:isDefinedBy>http://purl.org/spar/amo/isValidUnless</rdfs:isDefinedBy>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/twc/sudo/ontology#justify">
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/twc/sudo/ontology#leadsTo">
        <rdfs:comment>A warrant that points to a claim from the related evidence within an argument.</rdfs:comment>
        <rdfs:isDefinedBy>http://purl.org/spar/amo/leadsTo</rdfs:isDefinedBy>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/twc/sudo/ontology#mentions">
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/twc/sudo/ontology#motivates">
        <rdfs:comment>desire to perform action presented in the artifact is increased</rdfs:comment>
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/twc/sudo/ontology#proves">
        <rdfs:comment>An evidence that founds a claim of an argument.</rdfs:comment>
        <rdfs:isDefinedBy>http://purl.org/spar/amo/proves</rdfs:isDefinedBy>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/twc/sudo/ontology#purposes">
        <rdfs:comment>the activity in the artifact is initiated in order to realize the proposition.</rdfs:comment>
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/twc/sudo/ontology#responsesTo">
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/twc/sudo/ontology#restates">
        <rdfs:comment>a proposition as a restatement of the artifact.</rdfs:comment>
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/twc/sudo/ontology#result">
        <rdfs:comment>recognizes that the situation presented in the artifact, could be a cuase for the action or situation presented in the proposition.</rdfs:comment>
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/twc/sudo/ontology#solves">
        <rdfs:comment>The artifact is a solution to the problem stated in the proposition.</rdfs:comment>
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/twc/sudo/ontology#summarizes">
        <rdfs:comment>a proposition as a shorter restatement of the artifact.</rdfs:comment>
        <rdfs:seeAlso>https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf</rdfs:seeAlso>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/twc/sudo/ontology#supports">
        <rdfs:comment>An evidence that supports a warrant of an argument.</rdfs:comment>
        <rdfs:isDefinedBy>http://purl.org/spar/amo/supports</rdfs:isDefinedBy>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/twc/sudo/ontology#usedFor">
        <rdfs:seeAlso>http://arxiv.org/abs/1808.09602</rdfs:seeAlso>
    </rdf:Description>
</rdf:RDF>



