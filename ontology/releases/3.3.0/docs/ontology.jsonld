  } ]
}, {
  "@id" : "https://w3id.org/twc/sudo/ontology#Concept",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Concept"
  } ]
}, {
  "@id" : "https://w3id.org/twc/sudo/ontology#Condition",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "A realization of the situation presented in the proposition enables the realization of the situation presented in the artifact."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@value" : "https://www.sfu.ca/rst/05bibliographies/bibs/ISI_RS_87_190.pdf"
